colors {
  primary: #FF8A00          // ripe agbalumo skin
  earthDark: #1A120E        // deep obsidian soil
  earthClay: #A0522D        // burnt terracotta
  earthOchre: #CC7722       // sun-baked clay
  earthSand: #F4EBD0        // warm savannah dust
  earthCream: #FAF8F1       // Nigerian gardenia white
  secondary: #005D3A        // deep forest green
  accent: #F58608           // glowing citrus pop
}

radius {
  sm: 0px                   // strict sharp editorial
  md: 0px                   // no rounded corners
  lg: 0px                   // zero tolerance for softness
}

space {
  xs: 8px
  sm: 16px
  md: 24px
  lg: 48px
  xl: 80px                  // generous tropical breathing room
}

type {
  displayLarge: 42px / 700 / "Playfair Display" (serif - dominant editorial)
  headline: 28px / 600 / "Inter" (sans)
  body: 16px / 400 / "Inter" (sans)
  label: 14px / 500 / "Inter" (sans)
  micro: 10px / 600 / "Inter" (sans) uppercase tracking-widest // editorial controls
}

motion {
  durationShort: 200ms ease-out
  durationMedium: 300ms cubic-bezier(0.4, 0, 0.2, 1)  // juicy bounce
}