#!/usr/bin/env bash

# Antigravity Sandboxed Workspace Environment
# Source this file to redirect developmental tools to project-local directories.
# This allows 'go', 'gh', and other tools to operate within the macOS Sandbox
# without requiring Full Disk Access.

# 1. Go Environment Isolation
export GOPATH="$PWD/.tester/tmp/go"
export GOMODCACHE="$GOPATH/pkg/mod"
export GOCACHE="$GOPATH/cache"
export PATH="$GOPATH/bin:$PATH"

# 2. GitHub CLI Isolation
export GH_CONFIG_DIR="$PWD/.tester/tmp/gh"

# 3. Informational output
echo "🛡️  Sandboxed Workspace Mode Activated"
echo "📍 GOPATH: $GOPATH"
echo "📍 GH_CONFIG: $GH_CONFIG_DIR"
echo "💡 Note: You may need to run 'gh auth login' within this session."
